# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ── Supabase ───────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-only, gives full DB access (bypasses RLS)
# Found in: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Resend ─────────────────────────────────────────────────
# Found in: resend.com → API Keys
RESEND_API_KEY=re_your_resend_key_here

# ── Site ───────────────────────────────────────────────────
# Change to your real domain when deploying to Vercel
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email address that sends booking confirmations (must be verified in Resend)
# Use onboarding@resend.dev for testing, your domain email for production
RESEND_FROM_EMAIL=onboarding@resend.dev
